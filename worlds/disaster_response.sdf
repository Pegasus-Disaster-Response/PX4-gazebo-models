    </model>
    <model name="feature_cylinder_2">
      <pose>-15 30 3 0 0 0</pose>
      <static>true</static>
      <link name="link">
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>1.2</radius>
            <length>6</length>
          </cylinder>
        </geometry>
