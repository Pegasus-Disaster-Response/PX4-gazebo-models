    <model name="feature_box_1">
      <pose>5 -40 1.5 0 0 1.2</pose>
      <static>true</static>
      <link name="link">
      <collision name="collision">
        <geometry>
          <box>
            <size>4 3 3</size>
          </box>
        </geometry>
      </collision>
      <visual name="visual">
