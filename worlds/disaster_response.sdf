        </material>
      </visual>
      </link>
    </model>
    <!-- ════════════════════════════════════════════════════
         VTOL QUADPLANE — Pegasus Disaster Response UAV
         Simplified geometric model with simulated sensors:
           - VLP-16 LiDAR (gpu_lidar, 360°, 16 channels)
           - ZED X-approximating RGBD camera (105° HFOV)
           - IMU
         Spawn at origin, 0.5m above ground (on landing gear)
         ════════════════════════════════════════════════════ -->
    <model name="pegasus_vtol">
      <pose>0 0 0.5 0 0 0</pose>
      <static>false</static>

      <!-- ── Fuselage ──────────────────────────────────── -->
      <link name="base_link">
        <inertial>
          <mass>50.0</mass>
          <inertia>
            <ixx>5.0</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>12.0</iyy><iyz>0</iyz>
            <izz>15.0</izz>
          </inertia>
        </inertial>

        <!-- Fuselage body -->
        <collision name="fuselage_col">
          <pose>0 0 0 0 0 0</pose>
          <geometry><box><size>2.0 0.5 0.4</size></box></geometry>
        </collision>
        <visual name="fuselage_vis">
          <pose>0 0 0 0 0 0</pose>
          <geometry><box><size>2.0 0.5 0.4</size></box></geometry>
          <material>
            <ambient>0.15 0.15 0.2 1</ambient>
            <diffuse>0.2 0.2 0.3 1</diffuse>
            <specular>0.4 0.4 0.5 1</specular>
          </material>
        </visual>

        <!-- Main wing -->
        <visual name="wing_vis">
          <pose>0 0 0.05 0 0 0</pose>
          <geometry><box><size>0.8 4.572 0.06</size></box></geometry>
          <material>
            <ambient>0.18 0.18 0.22 1</ambient>
            <diffuse>0.25 0.25 0.32 1</diffuse>
            <specular>0.3 0.3 0.35 1</specular>
          </material>
        </visual>

        <!-- Tail boom -->
        <visual name="tail_boom_vis">
          <pose>-1.2 0 0.05 0 0 0</pose>
          <geometry><cylinder><radius>0.04</radius><length>1.0</length></cylinder></geometry>
          <material>
            <ambient>0.12 0.12 0.15 1</ambient>
            <diffuse>0.18 0.18 0.22 1</diffuse>
          </material>
        </visual>

        <!-- Horizontal tail -->
        <visual name="htail_vis">
          <pose>-1.7 0 0.05 0 0 0</pose>
          <geometry><box><size>0.35 1.2 0.04</size></box></geometry>
          <material>
            <ambient>0.18 0.18 0.22 1</ambient>
            <diffuse>0.25 0.25 0.32 1</diffuse>
          </material>
        </visual>

        <!-- Vertical tail -->
        <visual name="vtail_vis">
          <pose>-1.7 0 0.25 0 0 0</pose>
          <geometry><box><size>0.30 0.04 0.40</size></box></geometry>
          <material>
            <ambient>0.18 0.18 0.22 1</ambient>
            <diffuse>0.25 0.25 0.32 1</diffuse>
          </material>
        </visual>

        <!-- Front-left motor mount + prop disc -->
        <visual name="motor_fl_mount">
          <pose>0.4 1.0 0.15 0 0 0</pose>
          <geometry><cylinder><radius>0.03</radius><length>0.25</length></cylinder></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material>
        </visual>
        <visual name="prop_fl">
          <pose>0.4 1.0 0.30 0 0 0</pose>
          <geometry><cylinder><radius>0.25</radius><length>0.01</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 0.6</ambient><diffuse>0.15 0.15 0.15 0.6</diffuse></material>
        </visual>

        <!-- Front-right motor mount + prop disc -->
        <visual name="motor_fr_mount">
          <pose>0.4 -1.0 0.15 0 0 0</pose>
          <geometry><cylinder><radius>0.03</radius><length>0.25</length></cylinder></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material>
        </visual>
        <visual name="prop_fr">
          <pose>0.4 -1.0 0.30 0 0 0</pose>
          <geometry><cylinder><radius>0.25</radius><length>0.01</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 0.6</ambient><diffuse>0.15 0.15 0.15 0.6</diffuse></material>
        </visual>

        <!-- Rear-left motor mount + prop disc -->
        <visual name="motor_rl_mount">
          <pose>-0.4 1.0 0.15 0 0 0</pose>
          <geometry><cylinder><radius>0.03</radius><length>0.25</length></cylinder></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material>
        </visual>
        <visual name="prop_rl">
          <pose>-0.4 1.0 0.30 0 0 0</pose>
          <geometry><cylinder><radius>0.25</radius><length>0.01</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 0.6</ambient><diffuse>0.15 0.15 0.15 0.6</diffuse></material>
        </visual>

        <!-- Rear-right motor mount + prop disc -->
        <visual name="motor_rr_mount">
          <pose>-0.4 -1.0 0.15 0 0 0</pose>
          <geometry><cylinder><radius>0.03</radius><length>0.25</length></cylinder></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material>
        </visual>
        <visual name="prop_rr">
          <pose>-0.4 -1.0 0.30 0 0 0</pose>
          <geometry><cylinder><radius>0.25</radius><length>0.01</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 0.6</ambient><diffuse>0.15 0.15 0.15 0.6</diffuse></material>
        </visual>

        <!-- Landing gear skids -->
        <visual name="gear_left">
          <pose>0 0.3 -0.25 0 0 0</pose>
          <geometry><box><size>0.8 0.04 0.04</size></box></geometry>
          <material><ambient>0.25 0.25 0.25 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
        </visual>
        <visual name="gear_right">
          <pose>0 -0.3 -0.25 0 0 0</pose>
          <geometry><box><size>0.8 0.04 0.04</size></box></geometry>
          <material><ambient>0.25 0.25 0.25 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
        </visual>

        <!-- ── IMU Sensor ─────────────────────────────── -->
        <sensor name="imu_sensor" type="imu">
          <always_on>true</always_on>
          <update_rate>200</update_rate>
          <topic>/pegasus/imu/data</topic>
          <imu>
            <angular_velocity>
              <x><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></x>
              <y><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></y>
              <z><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></z>
            </angular_velocity>
            <linear_acceleration>
              <x><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></x>
              <y><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></y>
              <z><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></z>
            </linear_acceleration>
          </imu>
        </sensor>
      </link>

      <!-- ── VLP-16 LiDAR Link ─────────────────────────── -->
      <link name="velodyne">
        <pose relative_to="base_link">0 0 0.15 0 0 0</pose>
        <inertial>
          <mass>0.83</mass>
          <inertia>
            <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.001</iyy><iyz>0</iyz>
            <izz>0.001</izz>
          </inertia>
        </inertial>

        <visual name="vlp16_vis">
          <geometry><cylinder><radius>0.05</radius><length>0.07</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.15 0.15 0.15 1</diffuse>
          </material>
        </visual>

        <sensor name="vlp16" type="gpu_lidar">
          <always_on>true</always_on>
          <update_rate>10</update_rate>
          <topic>/velodyne_points/points</topic>
          <lidar>
            <scan>
              <horizontal>
                <samples>900</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
              </horizontal>
              <vertical>
                <samples>16</samples>
                <resolution>1</resolution>
                <min_angle>-0.261799</min_angle>
                <max_angle>0.261799</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.5</min>
              <max>100.0</max>
              <resolution>0.003</resolution>
            </range>
            <noise>
              <type>gaussian</type>
              <mean>0.0</mean>
              <stddev>0.01</stddev>
            </noise>
          </lidar>
          <visualize>true</visualize>
        </sensor>
      </link>

      <joint name="velodyne_joint" type="fixed">
        <parent>base_link</parent>
        <child>velodyne</child>
      </joint>

      <!-- ── ZED X Camera Link ─────────────────────────── -->
      <link name="camera_link">
        <pose relative_to="base_link">0.85 0 0.0 0 0 0</pose>
        <inertial>
          <mass>0.18</mass>
          <inertia>
            <ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.0001</iyy><iyz>0</iyz>
            <izz>0.0001</izz>
          </inertia>
        </inertial>

        <visual name="zed_vis">
          <geometry><box><size>0.04 0.17 0.03</size></box></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.12 0.12 0.12 1</diffuse>
          </material>
        </visual>

        <!-- RGB camera (ZED X approx) -->
        <sensor name="camera" type="camera">
          <always_on>true</always_on>
          <update_rate>15</update_rate>
          <topic>camera</topic>
          <camera>
            <horizontal_fov>1.8326</horizontal_fov>
            <image>
              <width>672</width>
              <height>376</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.3</near>
              <far>100.0</far>
            </clip>
            <noise>
              <type>gaussian</type>
              <mean>0.0</mean>
              <stddev>0.005</stddev>
            </noise>
          </camera>
        </sensor>

        <!-- Depth camera (ZED X neural depth approx) -->
        <sensor name="depth_camera" type="depth_camera">
          <always_on>true</always_on>
          <update_rate>15</update_rate>
          <topic>camera</topic>
          <camera>
            <horizontal_fov>1.8326</horizontal_fov>
            <image>
              <width>672</width>
              <height>376</height>
              <format>R_FLOAT32</format>
            </image>
            <clip>
              <near>0.3</near>
              <far>20.0</far>
            </clip>
            <noise>
              <type>gaussian</type>
              <mean>0.0</mean>
              <stddev>0.01</stddev>
            </noise>
          </camera>
        </sensor>
      </link>

      <joint name="camera_joint" type="fixed">
        <parent>base_link</parent>
        <child>camera_link</child>
      </joint>

    </model>

  </world>
</sdf>
