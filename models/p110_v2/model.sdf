          <ixz>0.00</ixz>
          <iyz>0.00</iyz>
          <izz>0.01</izz>
        </inertia>
      </inertial>
      <visual name='right_rudder_visual'>
          <pose>0 0 0 0 0 3.1216</pose>
        <geometry>
          <mesh>
            <!-- <scale>0.001 0.001 0.001</scale> -->
            <uri>model://p110_v2/meshes/rudder.STL</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0 0 1 1.0</ambient>
          <diffuse>0 0 1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="elevator">
      <pose> -1.925 0.606 0.295 0.00 0 0.0</pose>
      <inertial>
        <mass>1.88</mass>
        <pose>-0.05 -0.61 0 0 0 0</pose>
        <inertia>
          <ixx>0.28</ixx>
          <ixy>0.0</ixy>
          <iyy>0.01</iyy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
          <izz>0.29</izz>
        </inertia>
      </inertial>
      <visual name='elevator_visual'>
          <pose>0 0 0 1.5708 3.1416 0</pose>
        <geometry>
          <mesh>
            <!-- <scale>0.001 0.001 0.001</scale> -->
            <uri>model://p110_v2/meshes/elevator.STL</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0 0 1 1.0</ambient>
          <diffuse>0 0 1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name='servo_0' type='revolute'>
<!-- joint does not need pose, it will rotate at the origin of the child object -->
      <parent>base_link</parent>
      <child>left_elevon</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.52</lower>
          <upper>0.52</upper>
        </limit>
        <dynamics>
          <damping>2.0</damping>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </joint>
    <joint name='servo_1' type='revolute'>
      <parent>base_link</parent>
      <child>right_elevon</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.52</lower>
          <upper>0.52</upper>
        </limit>
        <dynamics>
          <damping>2.0</damping>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </joint>
    <joint name='servo_2' type='revolute'>
      <parent>base_link</parent>
      <child>elevator</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.52</lower>
          <upper>0.52</upper>
        </limit>
        <dynamics>
          <damping>1.5</damping>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </joint>
    <joint name='servo_3' type='revolute'>
      <parent>base_link</parent>
      <child>left_rudder</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.52</lower>
          <upper>0.52</upper>
        </limit>
        <dynamics>
          <damping>1.5</damping>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </joint>
    <joint name='servo_4' type='revolute'>
      <parent>base_link</parent>
      <child>right_rudder</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.52</lower>
          <upper>0.52</upper>
        </limit>
